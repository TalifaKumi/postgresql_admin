SELECT queryid, planid, plan FROM ext.pg_store_plans\gx
SELECT plan,
       queryid_stat_statements,
       calls,
       rows,
       total_time / 1000 AS total_time_in_seconds,
       max_time / 1000 AS max_time_in_seconds,
       stddev_time / 1000 AS staddev_time_in_seconds
FROM pg_store_plans
ORDER BY total_time DESC
LIMIT 5;


SELECT pg_store_plans_reset();
SELECT pg_stat_statements_reset();


SELECT s.query,
       p.plan,
       s.calls AS stmt_calls,
       p.calls AS plan_calls,
       p.total_time / p.calls AS "time/call"
FROM pg_stat_statements s
JOIN pg_store_plans p ON s.queryid = p.queryid_stat_statements
ORDER BY "time/call" DESC
LIMIT 4;

